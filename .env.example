# ── RAG App — Environment Variables ─────────────────────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env  (Windows)
#
# For backend local dev, see backend/.env.example
# ---------------------------------------------------------------------------

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose which LLM backend to use.
# Options:
#   groq   → Fast cloud API, no GPU needed. Requires GROQ_API_KEY below.
#   ollama → Local model via Ollama (llama3). No API key needed, but requires
#            Docker to download ~4 GB on first run.
LLM_PROVIDER=groq

# ── Groq (required when LLM_PROVIDER=groq) ───────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# (Optional) Override the default Groq model.
# See available models: https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.3-70b-versatile

# ── HuggingFace ──────────────────────────────────────────────────────────────
# (Optional) Only needed if using gated / restricted HuggingFace models.
# The default embedding and reranker models work without a token.
HF_TOKEN=

# ── CORS (Production only) ───────────────────────────────────────────────────
# If you're deploying to a real server with a domain, add it here.
# Comma-separated list. Example: https://myapp.example.com
EXTRA_CORS_ORIGINS=
