# ── Backend Environment Variables ──
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Docker-based usage, see ../.env.example at the project root.
# ---------------------------------------------------------------------------

# ── HuggingFace ──
# (Optional) Token for HuggingFace Hub access if using restricted models
HF_TOKEN=your_token_here

# ── LLM Provider ──
# Options: "ollama" (default) | "groq"
LLM_PROVIDER=ollama

# ── Groq (only needed when LLM_PROVIDER=groq) ──
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ── API ──
# Any other backend environment variables can go here
